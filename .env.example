# AI Assist — non-secret configuration inventory.
# Copy to `.env` and adjust. Secrets live in deploy/secrets/* files, NOT here.
# Never put passwords, tokens, signing keys or provider keys in this file.

# ---------------------------------------------------------------- application
APP_ENV=development                     # development | production
APP_BASE_URL=http://localhost:5173      # public origin; production: https://llm.roguelife.de
APP_TIMEZONE=Europe/Berlin              # default IANA timezone for new accounts
APP_DEFAULT_LOCALE=zh-CN
LOG_LEVEL=INFO

# Comma-separated allowed browser origins for CORS/CSRF Origin checks.
APP_ALLOWED_ORIGINS=http://localhost:5173

# ------------------------------------------------------------------- frontend
VITE_BASE_URL=/                         # SPA is mounted at the domain root
VITE_API_PROXY=http://localhost:8000    # dev-only proxy target for /api

# ------------------------------------------------------------------- database
POSTGRES_DB=aiassist
POSTGRES_USER=aiassist
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Password is read from deploy/secrets/postgres_password (see POSTGRES_PASSWORD_FILE).

# ---------------------------------------------------------------------- redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ------------------------------------------------------------------- rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=aiassist
RABBITMQ_VHOST=aiassist
# Password is read from deploy/secrets/rabbitmq_password.

# ------------------------------------------------------------- object storage
STORAGE_PROVIDER=local                  # local | s3
ASSET_ROOT=/data/assets                 # private volume, outside any web root
# S3 adapter (only when STORAGE_PROVIDER=s3):
S3_ENDPOINT_URL=
S3_BUCKET=aiassist
S3_REGION=us-east-1
# S3 keys are read from deploy/secrets/s3_access_key and deploy/secrets/s3_secret_key.

# --------------------------------------------------------------------- auth
ACCESS_TOKEN_TTL_SECONDS=900            # 15 minutes
REFRESH_TOKEN_TTL_SECONDS=1209600       # 14 days
LOGIN_MAX_ATTEMPTS=10                   # per account+IP window
LOGIN_WINDOW_SECONDS=900
# JWT signing key is read from deploy/secrets/jwt_signing_key.

# --------------------------------------------------------------------- uploads
UPLOAD_IMAGE_MAX_BYTES=26214400         # 25 MiB
UPLOAD_AUDIO_MAX_BYTES=52428800         # 50 MiB
UPLOAD_MARKDOWN_MAX_BYTES=2097152       # 2 MiB
UPLOAD_IMAGE_MAX_PIXELS=50000000        # 50 MP pixel-bomb guard

# ------------------------------------------------------------------- recurrence
RECURRENCE_LOOKAHEAD_DAYS=1             # plain recurring-task generation window (1..7)

# ----------------------------------------------------------------------- mail
# Optional. Unset => in-app reminders still work, email marked degraded.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_FROM=AI Assist <noreply@example.com>
SMTP_TLS_MODE=implicit                  # implicit (465) | starttls (587)
# SMTP password is read from deploy/secrets/smtp_password.

# ------------------------------------------------------------------------- llm
# Optional. Unset => AI features marked degraded; base saving unaffected.
LLM_PROVIDER=none                       # none | openai | anthropic | ollama
LLM_BASE_URL=
LLM_DEFAULT_MODEL=
SPEECH_PROVIDER=none                    # none | openai | faster_whisper | cloud
SPEECH_DEFAULT_MODEL=
# Provider key is read from deploy/secrets/llm_provider_key.

# --------------------------------------------------------------------- backups
BACKUP_RETENTION_DAYS=30
